# =============================================================================
# ToolzBanana — copy to `.env.local` (local) or Vercel Environment Variables
# =============================================================================
# cp .env.example .env.local
# =============================================================================

# --- REQUIRED FOR PRODUCTION SEO / ADSENSE SITE URL -------------------------
# Must match your live domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://toolzbanana.vercel.app

# --- GOOGLE ADSENSE (optional until account is approved) ---------------------
# Publisher ID is ALREADY in code + public/ads.txt — do NOT add env vars for it:
#   ca-pub-2466646777584490
#
# ONLY this ad variable is used by the app. Leave EMPTY until AdSense approves
# you and you create an ad unit (Ads → By ad unit → copy data-ad-slot value).
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=
#
# NOT USED by this project — remove if you have them:
#   NEXT_PUBLIC_ADSENSE_CLIENT
#   NEXT_PUBLIC_ADSENSE_SLOT_RECTANGLE
#   NEXT_PUBLIC_ADSENSE_SLOT_WIDE_SKYSCRAPER
#   NEXT_PUBLIC_ADSENSE_SLOT_LARGE_LEADERBOARD
#   NEXT_PUBLIC_ADSENSE_SLOT_BILLBOARD

# --- CONTACT FORM (optional) -------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=toolzbanana@gmail.com
SMTP_PASSWORD=
SMTP_FROM="Support Team <toolzbanana@gmail.com>"
CONTACT_TO_EMAIL=toolzbanana@gmail.com

# --- BACKGROUND REMOVER (optional — /tools/background-remover only) ------------
REMOVE_BG_API_KEY=
